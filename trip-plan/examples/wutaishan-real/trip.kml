      <Point><coordinates>113.601727,39.007652,0</coordinates></Point>
    </Placemark>
    <Placemark>
      <name>8. 普化寺素斋</name>
      <description><![CDATA[D2 晚餐 · 17:30 时段 · 普化寺素斋 · 错过吃不上<br/><br/>标签: food<br/>坐标(GCJ-02): 113.601028, 39.008453<br/>高德导航: <a href="https://uri.amap.com/navigation?to=113.601028,39.008453,%E6%99%AE%E5%8C%96%E5%AF%BA%E7%B4%A0%E6%96%8B&mode=car&src=wutaishan">点这里导航</a>]]></description>
